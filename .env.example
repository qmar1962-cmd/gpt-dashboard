# 环境变量配置示例
# 复制此文件为 .env.local 并填写实际值

# Gemini API Key (可选，如需使用 AI 功能)
# 获取地址: https://ai.google.dev/
GEMINI_API_KEY=

# 应用配置
VITE_APP_TITLE=GPT每日通报可视化看板
VITE_APP_VERSION=1.0.0

# 数据配置
VITE_DATA_PATH=./数据库
VITE_ENABLE_OFFLINE=true

# 功能开关
VITE_ENABLE_EXPORT=true
VITE_ENABLE_PRINT=true
VITE_ENABLE_FULLSCREEN=true
